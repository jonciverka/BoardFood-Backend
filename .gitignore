# ##############################################################################
# .gitignore para proyectos de Node.js
# ##############################################################################

# Dependencias (Nunca las subas, se regeneran con 'npm install')
node_modules/
jspm_packages/
web_modules/

# Archivos de entorno / Secretos (¡CRÍTICO! Nunca subas tus contraseñas o API keys)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Carpetas de compilación / Distribución (Salida de Babel, TypeScript, Webpack, etc.)
dist/
build/
out/
.next/
.nuxt/

# Logs del sistema y de npm
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Diagnósticos y reportes de cobertura de pruebas (Jest, Istanbul, etc.)
coverage/
.nyc_output/
.jest/

# Archivos temporales o de caché
.eslintcache
.stylelintcache
.npm
.eslintcache
.cache/

# Archivos específicos del Sistema Operativo (Basura del sistema)
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Configuraciones de editores de código comunes (Opcional, pero recomendado)
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?